{
  "expo": {
    "name": "ora-mobile",
    "slug": "ora-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.edlin.ora",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "ORA precisa do microfone para ouvir você.",
        "NSHealthShareUsageDescription": "ORA lê seus dados de saúde para personalizar recomendações e monitorar seu progresso.",
        "NSHealthUpdateUsageDescription": "ORA pode registrar métricas de saúde quando você as reportar."
      },
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.access": []
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-audio",
        {
          "microphonePermission": "ORA precisa do microfone para ouvir você."
        }
      ],
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "ORA usa sua localização para personalizar respostas com clima e contexto local."
        }
      ],
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#4361ee",
          "sounds": []
        }
      ]
    ]
  }
}
