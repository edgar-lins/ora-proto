# String de conexão PostgreSQL
DATABASE_URL=postgres://ora:ora123@localhost:5432/ora

# Chave da API OpenAI
OPENAI_API_KEY=sk-...

# Porta do servidor (padrão: 3000)
PORT=3000

# URL base deste servidor (usada para chamadas internas entre rotas)
# Em produção, defina como a URL pública, ex: https://api.seudominio.com
BASE_URL=http://localhost:3000

# Modelo de transcrição de áudio (opcional, padrão: gpt-4o-mini-transcribe)
# TRANSCRIBE_MODEL=whisper-1

# Google OAuth (para integração com Google Calendar)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/auth/google/callback
